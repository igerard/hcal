            "value" : "Réinitialiser"
          }
        }
      }
    },
    "Rosh Hashanah (1-2 Tishrei): the Jewish New Year and Day of Judgment. The shofar is sounded, opening the Ten Days of Repentance toward Yom Kippur." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Roch Hachana (1-2 Tichri) : le Nouvel An juif et Jour du Jugement. On sonne du chofar, ouvrant les Dix Jours de pénitence qui mènent à Yom Kippour."
          }
        }
      }
    },
    "Rosh Hashanah: the Jewish New Year and Day of Judgment, when the shofar is sounded." : {
      "extractionState" : "stale",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Roch Hachana : le Nouvel An juif et Jour du Jugement, où l’on sonne du chofar."
          }
        }
      }
    },
    "Selichot: penitential prayers recited in the run-up to the High Holy Days." : {
      "extractionState" : "stale",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
