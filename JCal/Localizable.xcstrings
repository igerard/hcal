    "Counting of the Omer" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Compte de l’Omer"
          }
        }
      }
    },
    "Counting of the Omer: the 49 days counted from the second night of Pesach until Shavuot." : {
      "extractionState" : "stale",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Décompte du Omer : les 49 jours comptés depuis la deuxième nuit de Pessah jusqu’à Chavouot."
          }
        }
      }
    },
    "Counting of the Omer: the daily count of the 49 days from the second night of Pesach to Shavuot. Each evening the new day is recited, linking the Exodus to the giving of the Torah." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Décompte du Omer : le décompte quotidien des 49 jours depuis la deuxième nuit de Pessah jusqu’à Chavouot. Chaque soir, on récite le jour nouveau, reliant la sortie d’Égypte au don de la Torah."
          }
        }
      }
    },
    "Credits" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Crédits"
          }
        }
      }
    },
    "Diaspora" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Diaspora"
          }
        }
      }
    },
    "Erev Hanukah: the eve of Hanukah; the first light is kindled at nightfall on 25 Kislev." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Erev Hanoucca : la veille de Hanoucca ; la première lumière est allumée à la tombée de la nuit, le 25 Kislev."
          }
        }
      }
    },
    "Erev Hanukah: the eve of Hanukah." : {
      "extractionState" : "stale",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Erev Hanoucca : la veille de Hanoucca."
          }
        }
      }
    },
    "Erev Pesach: the eve of Passover (14 Nissan). The morning is devoted to removing and burning chametz, firstborn traditionally fast, and the Seder begins that night." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Erev Pessah : la veille de Pâque (14 Nissan). La matinée est consacrée à retirer et à brûler le hametz, les premiers-nés jeûnent traditionnellement, et le Séder commence ce soir-là."
          }
        }
      }
    },
    "Erev Pesach: the eve of Passover, when leaven is removed and the Seder is prepared." : {
      "extractionState" : "stale",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Erev Pessah : la veille de Pâque, lorsque l’on retire le levain et que l’on prépare le Séder."
          }
        }
      }
    },
    "Erev Purim: the eve of Purim, when the festival begins at nightfall with the first reading of the Megillah." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Erev Pourim : la veille de Pourim, lorsque la fête commence à la tombée de la nuit avec la première lecture de la Méguila."
          }
        }
      }
    },
    "Erev Purim: the eve of Purim." : {
      "extractionState" : "stale",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Erev Pourim : la veille de Pourim."
          }
        }
      }
    },
    "Erev Rosh Hashanah (29 Elul): the eve of the Jewish New Year, with candle-lighting and festive meals featuring symbolic foods." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Erev Roch Hachana (29 Elloul) : la veille du Nouvel An juif, avec l’allumage des bougies et des repas festifs comportant des aliments symboliques."
          }
        }
      }
    },
    "Erev Rosh Hashanah: the eve of the Jewish New Year." : {
      "extractionState" : "stale",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Erev Roch Hachana : la veille du Nouvel An juif."
          }
        }
      }
    },
    "Erev Shavuot: the eve of Shavuot, at the end of the seven-week Omer count. Many stay up studying Torah through the night (Tikkun Leil Shavuot)." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Erev Chavouot : la veille de Chavouot, à la fin des sept semaines du décompte du Omer. Beaucoup veillent toute la nuit pour étudier la Torah (Tikkoun Leil Chavouot)."
          }
        }
      }
    },
    "Erev Shavuot: the eve of Shavuot." : {
      "extractionState" : "stale",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Erev Chavouot : la veille de Chavouot."
          }
        }
      }
    },
    "Erev Sukkot (14 Tishrei): the eve of Sukkot, when the sukkah is completed and the Four Species are prepared." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Erev Souccot (14 Tichri) : la veille de Souccot, lorsque l’on achève la souccah et que l’on prépare les Quatre Espèces."
          }
        }
      }
    },
    "Erev Sukkot: the eve of Sukkot." : {
      "extractionState" : "stale",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Erev Souccot : la veille de Souccot."
          }
        }
      }
    },
    "Erev Yom Kippur (9 Tishrei): the eve of the Day of Atonement, marked by a festive meal before the fast, charity, and seeking forgiveness from others." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Erev Yom Kippour (9 Tichri) : la veille du Jour du Grand Pardon, marquée par un repas festif avant le jeûne, des dons de charité et la demande de pardon à autrui."
          }
        }
      }
    },
    "Erev Yom Kippur: the eve of the Day of Atonement." : {
      "extractionState" : "stale",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Erev Yom Kippour : la veille du Jour du Grand Pardon."
