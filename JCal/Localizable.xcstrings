    "Parashat %@: the weekly Torah portion read on this Shabbat." : {
      "extractionState" : "stale",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Paracha %@ : la section hebdomadaire de la Torah lue ce Chabbat."
          }
        }
      }
    },
    "Parashat %@: the weekly Torah portion read on this Shabbat. The Torah is divided into 54 portions read across the year, completed on Simchat Torah." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Paracha %@ : la section hebdomadaire de la Torah lue ce Chabbat. La Torah est divisée en 54 sections lues au fil de l’année, achevées à Sim’hat Torah."
          }
        }
      }
    },
    "Parsha" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Paracha"
          }
        }
      }
    },
    "Pesach (Passover): begins 15 Nissan, lasting seven days in Israel and eight in the Diaspora. It commemorates the Exodus from Egypt; Jews eat matzah, avoid leaven, and retell the story at the Seder." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Pessah (Pâque) : commence le 15 Nissan et dure sept jours en Israël et huit en Diaspora. Elle commémore la sortie d’Égypte ; les Juifs mangent de la matsa, évitent le levain et racontent l’histoire lors du Séder."
          }
        }
      }
    },
    "Pesach (Passover): commemorates the Exodus from Egypt; matzah is eaten and leaven avoided." : {
      "extractionState" : "stale",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Pessah (Pâque) : commémore la sortie d’Égypte ; on mange de la matsa et l’on évite le levain."
          }
        }
      }
    },
    "Previous Month" : {
      "localizations" : {
