    "Chol Hamoed" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Hol Hamoed"
          }
        }
      }
    },
    "Chol Hamoed: the intermediate days of Pesach and Sukkot, between the opening and closing holy days. Some work is permitted while the festive character continues." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Hol Hamoed : les jours intermédiaires de Pessah et de Souccot, entre les jours saints d’ouverture et de clôture. Certains travaux sont permis tandis que le caractère festif se poursuit."
          }
        }
      }
    },
    "Chol Hamoed: the intermediate festival days of Pesach or Sukkot." : {
      "extractionState" : "stale",
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Hol Hamoed : les jours intermédiaires de la fête de Pessah ou de Souccot."
          }
        }
      }
    },
    "Click a day to read its holidays and events." : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "machine_translated",
            "value" : "Cliquez sur un jour pour voir ses fêtes et événements."
          }
        }
      }
    },
    "Color legend" : {
      "localizations" : {
